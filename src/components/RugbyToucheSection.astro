---
import { t, type Locale } from '../i18n';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const i = t(locale);

const benefits = [
  { icon: 'diversity_3', label: i.touche.benefits.mixed },
  { icon: 'do_not_disturb_on', label: i.touche.benefits.noContact },
  { icon: 'group_add', label: i.touche.benefits.allLevels },
  { icon: 'monitor_heart', label: i.touche.benefits.fitness },
];
---

<section id="rugby-touche" class="py-24 bg-surface relative overflow-hidden">
  <div class="absolute -top-12 -left-20 opacity-[0.04] pointer-events-none hidden lg:block">
    <span class="material-symbols-outlined text-[500px] text-primary" style="font-variation-settings: 'FILL' 1;">touch_app</span>
  </div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
      <div class="lg:col-span-7">
        <div class="inline-flex items-center gap-2 mb-4">
          <span class="text-secondary font-bold tracking-widest text-sm uppercase">{i.touche.kicker}</span>
          <span class="text-[0.65rem] font-bold uppercase tracking-wider px-2 py-0.5 rounded bg-tertiary-fixed text-on-tertiary-fixed">{i.touche.tag}</span>
        </div>
        <h2 class="font-headline text-4xl md:text-5xl font-bold text-primary mb-6 leading-tight">{i.touche.title}</h2>
        <p class="text-on-surface text-xl font-medium leading-snug mb-5">{i.touche.lead}</p>
        <p class="text-on-surface-variant text-lg leading-relaxed mb-10">{i.touche.body}</p>

        <div class="grid grid-cols-2 gap-4 mb-10">
          {benefits.map((b) => (
            <div class="flex items-center gap-3 bg-surface-container-low rounded-xl px-4 py-3">
              <span class="material-symbols-outlined text-secondary text-2xl flex-none" style="font-variation-settings: 'FILL' 1;">{b.icon}</span>
              <span class="font-headline font-bold text-primary text-sm">{b.label}</span>
            </div>
          ))}
        </div>

        <a href="#join" class="inline-flex items-center gap-2 bg-primary text-on-primary px-6 py-3 rounded-md font-bold hover:scale-105 transition-transform">
          <span class="material-symbols-outlined">app_registration</span>
          {i.touche.cta}
        </a>
      </div>

      <div class="lg:col-span-5">
        <div class="aspect-[4/5] rounded-3xl relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-secondary via-[#8a1118] to-primary"></div>
          <div class="absolute inset-0 flex items-center justify-center text-white/15">
            <span class="material-symbols-outlined" style="font-size: 220px; font-variation-settings: 'FILL' 1;">touch_app</span>
          </div>
          <div class="absolute bottom-8 left-8 right-8 z-10">
            <div class="font-headline text-white text-7xl md:text-8xl font-bold leading-none mb-2">5</div>
            <div class="font-headline text-white/90 text-2xl md:text-3xl font-bold leading-tight">
              {locale === 'fr' ? 'contre 5.' : 'on 5.'}
            </div>
            <div class="text-white/70 text-sm uppercase tracking-wider font-bold mt-3">
              {locale === 'fr' ? 'Sans contact. Tous niveaux.' : 'No contact. All levels.'}
            </div>
          </div>
          <div class="absolute top-8 right-8 inline-flex items-center gap-1.5 bg-white/15 backdrop-blur-sm text-white px-3 py-1 rounded text-[0.7rem] font-bold uppercase tracking-wider">
            {locale === 'fr' ? '18 ans et +' : '18+'}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

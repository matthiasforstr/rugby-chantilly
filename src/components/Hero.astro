---
import { t, type Locale } from '../i18n';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const i = t(locale);
---

<section class="relative min-h-[700px] md:min-h-[921px] flex items-center overflow-hidden pt-16">
  <div class="absolute inset-0 z-0">
    <img
      src="/images/hero/hero-placeholder.svg"
      alt=""
      class="w-full h-full object-cover"
      data-todo="Replace with: intense rugby player action shot, landscape ≥2400×1350, jpg/webp"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-primary/90 via-primary/60 to-transparent"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 w-full">
    <div class="max-w-2xl">
      <h1 class="font-headline text-6xl md:text-8xl font-bold text-on-primary leading-none tracking-tight mb-6">
        <span class="block text-on-primary/90 text-3xl md:text-5xl font-medium tracking-wide mb-2 label">{i.hero.kicker}</span>
        <span class="text-secondary">{i.hero.headline}</span>
      </h1>
      <p class="text-on-primary/80 text-xl mb-10 font-medium max-w-xl">
        {i.hero.sub}
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="#join" class="bg-secondary text-on-secondary px-8 py-4 rounded-md font-bold text-lg hover:scale-105 transition-transform inline-block text-center">
          {i.hero.ctaPrimary}
        </a>
        <a href="#matches" class="border border-white/30 backdrop-blur-sm text-white px-8 py-4 rounded-md font-bold text-lg hover:bg-white/10 transition-colors inline-block text-center">
          {i.hero.ctaSecondary}
        </a>
      </div>
    </div>
  </div>
</section>

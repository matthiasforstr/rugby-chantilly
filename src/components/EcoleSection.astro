---
import { t, type Locale } from '../i18n';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const i = t(locale);

const ageGroups = [
  i.school.ages.baby,
  i.school.ages.u8,
  i.school.ages.u10,
  i.school.ages.u12,
  i.school.ages.u14,
];
---

<section id="school" class="bg-surface-container-low">
  <!-- École de Rugby block -->
  <div class="py-24 max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
      <div class="lg:col-span-5 lg:sticky lg:top-32">
        <div class="aspect-square bg-primary rounded-3xl relative overflow-hidden">
          <div class="absolute inset-0 rugby-gradient opacity-90"></div>
          <div class="absolute inset-0 flex items-center justify-center text-on-primary/20">
            <span class="material-symbols-outlined" style="font-size: 280px;">groups</span>
          </div>
          <div class="absolute bottom-8 left-8 right-8 z-10">
            <p class="font-headline text-on-primary text-3xl md:text-4xl font-bold leading-tight">
              {locale === 'fr' ? 'Le rugby commence ici.' : 'Rugby starts here.'}
            </p>
          </div>
          <div class="absolute top-8 right-8 bg-secondary text-on-secondary px-3 py-1 rounded text-xs font-bold uppercase tracking-wider">
            {locale === 'fr' ? '4-14 ans' : 'Ages 4-14'}
          </div>
          <div class="absolute top-8 left-8 inline-flex items-center gap-1.5 bg-white/15 backdrop-blur-sm text-on-primary px-3 py-1 rounded text-[0.7rem] font-bold uppercase tracking-wider">
            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">verified</span>
            {i.school.label}
          </div>
        </div>
      </div>

      <div class="lg:col-span-7">
        <p class="text-secondary font-bold tracking-widest text-sm uppercase mb-4">{i.school.kicker}</p>
        <h2 class="font-headline text-4xl md:text-5xl font-bold text-primary mb-6">{i.school.title}</h2>
        <p class="text-on-surface-variant text-lg leading-relaxed mb-10">{i.school.body}</p>

        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-2 xl:grid-cols-3 gap-3 mb-10">
          {ageGroups.map((g) => (
            <div class="bg-surface-container-lowest rounded-xl p-5">
              <span class="material-symbols-outlined text-secondary text-3xl mb-3 block" style="font-variation-settings: 'FILL' 1;">{g.icon}</span>
              <div class="font-headline font-bold text-primary text-lg leading-tight">{g.label}</div>
              <div class="text-on-surface-variant text-sm mt-1">{g.range}</div>
            </div>
          ))}
        </div>

        <a href="#join" class="inline-flex items-center gap-2 bg-primary text-on-primary px-6 py-3 rounded-md font-bold hover:scale-105 transition-transform">
          <span class="material-symbols-outlined">app_registration</span>
          {i.school.cta}
        </a>
      </div>
    </div>
  </div>

  <!-- U16 Cadets — separate group, outside Rugby School -->
  <div class="border-t border-outline-variant/20">
    <div class="py-20 max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-7 order-2 lg:order-1">
          <div class="inline-flex items-center gap-2 mb-4">
            <span class="text-secondary font-bold tracking-widest text-sm uppercase">{i.school.u16.kicker}</span>
            <span class="text-[0.65rem] font-bold uppercase tracking-wider px-2 py-0.5 rounded bg-secondary/10 text-secondary">{i.school.u16.label}</span>
          </div>
          <h3 class="font-headline text-3xl md:text-4xl font-bold text-primary mb-5">{i.school.u16.title}</h3>
          <p class="text-on-surface-variant text-lg leading-relaxed mb-8">{i.school.u16.body}</p>
          <a href="#join" class="inline-flex items-center gap-2 text-primary font-bold border-b-2 border-secondary pb-1 hover:text-secondary transition-colors">
            {i.school.cta}
            <span class="material-symbols-outlined text-base">arrow_forward</span>
          </a>
        </div>

        <div class="lg:col-span-5 order-1 lg:order-2">
          <div class="bg-surface-container rounded-2xl p-8 flex flex-col items-center text-center relative overflow-hidden">
            <span class="material-symbols-outlined text-primary/10 text-[200px] absolute -bottom-8 -right-8 pointer-events-none" style="font-variation-settings: 'FILL' 1;">sports_rugby</span>
            <span class="material-symbols-outlined text-secondary text-5xl mb-4 relative z-10" style="font-variation-settings: 'FILL' 1;">military_tech</span>
            <div class="font-headline font-bold text-primary text-5xl md:text-6xl mb-2 relative z-10">U16</div>
            <div class="text-on-surface-variant uppercase tracking-wider text-sm font-bold relative z-10">
              {locale === 'fr' ? '15 à 16 ans' : 'Ages 15-16'}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

---
import { t, type Locale } from '../i18n';
import { getTikTokEmbeds } from '../lib/tiktok';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const i = t(locale);

const embeds = await getTikTokEmbeds();
const hasEmbeds = embeds.length > 0;
---

{hasEmbeds && (
  <section class="py-24 bg-surface-container-high overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 mb-12">
      <div class="flex items-center gap-4">
        <h2 class="font-headline text-4xl font-bold text-primary">{i.tiktok.title}</h2>
        <div class="h-px flex-1 bg-outline-variant/30"></div>
        <a
          href="https://www.tiktok.com/@rugby.olympique.c"
          target="_blank"
          rel="noopener"
          class="hidden md:flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-outline-variant/20 hover:bg-secondary hover:text-white hover:border-secondary transition-colors text-primary font-bold text-sm"
        >
          <span class="material-symbols-outlined text-base">video_library</span>
          @rugby.olympique.c
        </a>
      </div>
    </div>

    <div class="flex gap-6 px-6 overflow-x-auto pb-8 no-scrollbar scroll-smooth snap-x">
      {embeds.map((e) => (
        <div class="snap-start flex-none w-80 bg-primary rounded-xl overflow-hidden relative tiktok-card">
          {e.html ? (
            <div class="tiktok-embed-wrap" set:html={e.html} />
          ) : (
            <a href={e.url} target="_blank" rel="noopener" class="block h-[500px] relative group">
              {e.thumbnail_url ? (
                <img src={e.thumbnail_url} alt={e.title ?? 'TikTok'} class="w-full h-full object-cover opacity-80 group-hover:scale-110 transition-transform duration-500" />
              ) : (
                <div class="w-full h-full bg-gradient-to-b from-primary to-primary-deep" />
              )}
              <div class="absolute inset-0 bg-gradient-to-t from-primary via-transparent to-transparent"></div>
              <div class="absolute bottom-0 p-6">
                <div class="flex items-center gap-2 mb-2">
                  <span class="material-symbols-outlined text-white" style="font-variation-settings: 'FILL' 1;">play_circle</span>
                  <span class="text-white font-label text-xs font-bold uppercase tracking-wider">{e.author_name ?? 'TikTok'}</span>
                </div>
                {e.caption && <p class="text-white font-medium text-sm line-clamp-3">{e.caption}</p>}
              </div>
            </a>
          )}
        </div>
      ))}
    </div>

    <script async src="https://www.tiktok.com/embed.js"></script>
  </section>
)}

<style>
  .tiktok-card { min-height: 500px; }
  .tiktok-embed-wrap :global(.tiktok-embed) {
    margin: 0 !important;
    background: var(--color-primary) !important;
  }
  .tiktok-embed-wrap :global(iframe) { border-radius: 0.75rem; }
</style>

---
import { t, type Locale } from '../i18n';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const i = t(locale);

const benefits = [
  { icon: 'visibility', label: i.partners.benefits.visibility },
  { icon: 'hub', label: i.partners.benefits.network },
  { icon: 'school', label: i.partners.benefits.formation },
  { icon: 'star', label: i.partners.benefits.vip },
];
---

<section id="partners" class="py-24 bg-surface relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="font-headline text-4xl md:text-5xl font-bold text-primary mb-6">{i.partners.title}</h2>
        <p class="text-secondary font-bold tracking-widest text-sm uppercase mb-4">{i.partners.kicker}</p>
        <p class="text-on-surface-variant text-lg leading-relaxed mb-8">
          {i.partners.body}
        </p>
        <div class="grid grid-cols-2 gap-6">
          {benefits.map((b) => (
            <div class="flex items-center gap-3">
              <span class="material-symbols-outlined text-secondary font-bold">{b.icon}</span>
              <span class="text-primary font-bold">{b.label}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="bg-surface-container-low p-8 rounded-2xl border border-outline-variant/30 shadow-xl relative">
        <div class="absolute -top-4 -right-4 bg-secondary text-on-secondary px-4 py-1 rounded font-bold text-sm transform rotate-3">{i.partners.form.badge}</div>
        <form class="space-y-6" action="#" method="post">
          <div>
            <label class="block text-sm font-bold text-primary mb-2 uppercase tracking-tight" for="company">{i.partners.form.company}</label>
            <input class="w-full bg-white border border-outline-variant rounded-md px-4 py-3 focus:ring-2 focus:ring-secondary focus:border-transparent transition-all outline-none" id="company" name="company" placeholder={i.partners.form.companyPlaceholder} type="text" />
          </div>
          <div>
            <label class="block text-sm font-bold text-primary mb-2 uppercase tracking-tight" for="email">{i.partners.form.email}</label>
            <input class="w-full bg-white border border-outline-variant rounded-md px-4 py-3 focus:ring-2 focus:ring-secondary focus:border-transparent transition-all outline-none" id="email" name="email" placeholder={i.partners.form.emailPlaceholder} type="email" />
          </div>
          <div>
            <label class="block text-sm font-bold text-primary mb-2 uppercase tracking-tight" for="message">{i.partners.form.message}</label>
            <textarea class="w-full bg-white border border-outline-variant rounded-md px-4 py-3 focus:ring-2 focus:ring-secondary focus:border-transparent transition-all outline-none h-32 resize-none" id="message" name="message" placeholder={i.partners.form.messagePlaceholder}></textarea>
          </div>
          <button class="w-full bg-primary text-on-primary py-4 rounded-md font-bold text-lg hover:bg-primary/90 transition-colors shadow-lg active:scale-[0.98]" type="submit">
            {i.partners.form.submit}
          </button>
        </form>
      </div>
    </div>
  </div>

  <div class="absolute top-1/2 left-0 -translate-y-1/2 opacity-[0.03] -translate-x-1/4 pointer-events-none hidden lg:block">
    <span class="material-symbols-outlined text-[600px]">handshake</span>
  </div>
</section>

---
import Layout from '../../layouts/Layout.astro';
import { t } from '../../i18n';

const i = t('fr');
---

<Layout locale="fr">
  <main class="px-6 py-16 md:px-12 md:py-20">
    <section class="max-w-6xl mx-auto">
      <p class="label text-secondary text-label-sm mb-4">— Chantilly Rugby Club</p>
      <h1 class="display text-display-lg font-bold text-primary leading-[0.95]">
        {i.hero.headline}
      </h1>
      <p class="mt-6 text-body-lg max-w-xl text-on-surface/80">{i.hero.sub}</p>
    </section>

    <section class="mt-20 max-w-6xl mx-auto">
      <p class="text-body-md text-on-surface/60">
        Site en construction. Le design system "Heritage Tactician" est en place.
      </p>
    </section>
  </main>
</Layout>
